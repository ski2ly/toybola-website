// ============================================
// КОНТЕНТ СТРАНИЦ (Page Blocks)
// ============================================
model PageBlock {
  id          Int      @id @default(autoincrement())
  page        String   // "home", "about", "catalog", etc.
  blockType   String   // "hero", "stats", "partners", "factory", "export", "contact_form", "text", "image", "products"
  title       String   // Название блока для админки
  isEnabled   Boolean  @default(true)
  order       Int      @default(0)
  
  // Контент блока (JSON структура зависит от blockType)
  content     Json     
  
  // Настройки отображения
  bgColor     String   @default("white") // "white", "gray", "gradient"
  paddingTop  String   @default("lg")    // "sm", "md", "lg", "xl"
  paddingBottom String @default("lg")
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([page, order])
  @@index([page, isEnabled])
  @@map("page_blocks")
}
