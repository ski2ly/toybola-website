generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// КАТЕГОРИИ (верхний уровень)
// ============================================
model Category {
  id          Int      @id @default(autoincrement())
  nameRu      String   @map("name_ru")
  nameEn      String   @map("name_en")
  nameUz      String   @map("name_uz")
  slug        String   @unique
  descriptionRu String? @map("description_ru") @db.Text
  descriptionEn String? @map("description_en") @db.Text
  descriptionUz String? @map("description_uz") @db.Text
  imageUrl    String?  @map("image_url")
  sortOrder   Int      @default(0) @map("sort_order")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  subcategories Subcategory[]

  @@index([slug])
  @@index([isActive])
  @@map("categories")
}

// ============================================
// ПОДКАТЕГОРИИ
// ============================================
model Subcategory {
  id          Int      @id @default(autoincrement())
  categoryId  Int      @map("category_id")
  nameRu      String   @map("name_ru")
  nameEn      String   @map("name_en")
  nameUz      String   @map("name_uz")
  slug        String
  descriptionRu String? @map("description_ru") @db.Text
  descriptionEn String? @map("description_en") @db.Text
  descriptionUz String? @map("description_uz") @db.Text
  imageUrl    String?  @map("image_url")
  sortOrder   Int      @default(0) @map("sort_order")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  products Product[]

  @@unique([categoryId, slug])
  @@index([categoryId])
  @@index([isActive])
  @@map("subcategories")
}

// ============================================
// ПРОДУКТЫ
// ============================================
model Product {
  id              Int      @id @default(autoincrement())
  sku             String   @unique
  nameRu          String   @map("name_ru")
  nameEn          String   @map("name_en")
  nameUz          String   @map("name_uz")
  slug            String   @unique
  descriptionRu   String?  @map("description_ru") @db.Text
  descriptionEn   String?  @map("description_en") @db.Text
  descriptionUz   String?  @map("description_uz") @db.Text
  subcategoryId   Int?     @map("subcategory_id")
  dimensions      String?
  weightKg        Decimal? @map("weight_kg") @db.Decimal(8, 3)
  recommendedAge  String?  @map("recommended_age")
  material        String?
  packagingType   String?  @map("packaging_type")
  moq             Int      @default(1)
  priceMinUsd     Decimal? @map("price_min_usd") @db.Decimal(10, 2)
  priceMaxUsd     Decimal? @map("price_max_usd") @db.Decimal(10, 2)
  availability    String   @default("in_stock")
  isFeatured      Boolean  @default(false) @map("is_featured")
  isNew           Boolean  @default(false) @map("is_new")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  subcategory Subcategory? @relation(fields: [subcategoryId], references: [id], onDelete: SetNull)
  images      ProductImage[]
  attributes  ProductAttribute[]

  @@index([sku])
  @@index([subcategoryId])
  @@index([availability])
  @@index([isFeatured])
  @@index([isNew])
  @@index([slug])
  @@map("products")
}

// ============================================
// ИЗОБРАЖЕНИЯ ПРОДУКТОВ
// ============================================
model ProductImage {
  id         Int      @id @default(autoincrement())
  productId  Int      @map("product_id")
  imageUrl   String   @map("image_url")
  altText    String?  @map("alt_text")
  sortOrder  Int      @default(0) @map("sort_order")
  isPrimary  Boolean  @default(false) @map("is_primary")
  createdAt  DateTime @default(now()) @map("created_at")

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@map("product_images")
}

// ============================================
// АТРИБУТЫ ПРОДУКТОВ
// ============================================
model ProductAttribute {
  id             Int      @id @default(autoincrement())
  productId      Int      @map("product_id")
  attributeName  String   @map("attribute_name")
  attributeValue String   @map("attribute_value")
  createdAt      DateTime @default(now()) @map("created_at")

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, attributeName])
  @@index([productId])
  @@map("product_attributes")
}

// ============================================
// АДМИН ПОЛЬЗОВАТЕЛИ
// ============================================
model AdminUser {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  name      String
  role      String   @default("admin")
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("admin_users")
}

// ============================================
// ЛОГИ ИМПОРТА
// ============================================
model ImportLog {
  id           Int      @id @default(autoincrement())
  fileName     String   @map("file_name")
  status       String
  createdCount Int      @default(0) @map("created_count")
  updatedCount Int      @default(0) @map("updated_count")
  errorCount   Int      @default(0) @map("error_count")
  errors       Json?
  createdAt    DateTime @default(now()) @map("created_at")

  @@map("import_logs")
}
