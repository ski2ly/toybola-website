generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

// ============================================
// КАТЕГОРИИ (верхний уровень)
// ============================================
model Category {
  id          Int      @id @default(autoincrement())
  nameRu      String
  nameEn      String
  nameUz      String
  slug        String   @unique
  descriptionRu String?
  descriptionEn String?
  descriptionUz String?
  imageUrl    String?
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  subcategories Subcategory[]

  @@index([slug])
  @@index([isActive])
  @@map("categories")
}

// ============================================
// ПОДКАТЕГОРИИ
// ============================================
model Subcategory {
  id          Int      @id @default(autoincrement())
  categoryId  Int
  nameRu      String
  nameEn      String
  nameUz      String
  slug        String
  descriptionRu String?
  descriptionEn String?
  descriptionUz String?
  imageUrl    String?
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  products Product[]

  @@unique([categoryId, slug])
  @@index([categoryId])
  @@index([isActive])
  @@map("subcategories")
}

// ============================================
// ПРОДУКТЫ
// ============================================
model Product {
  id              Int      @id @default(autoincrement())
  sku             String   @unique
  nameRu          String
  nameEn          String
  nameUz          String
  slug            String   @unique
  descriptionRu   String?
  descriptionEn   String?
  descriptionUz   String?
  subcategoryId   Int?
  dimensions      String?
  weightKg        Float?
  recommendedAge  String?
  material        String?
  packagingType   String?
  moq             Int      @default(1)
  priceMinUsd     Float?
  priceMaxUsd     Float?
  availability    String   @default("in_stock")
  isFeatured      Boolean  @default(false)
  isNew           Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  subcategory Subcategory? @relation(fields: [subcategoryId], references: [id], onDelete: SetNull)
  images      ProductImage[]
  attributes  ProductAttribute[]

  @@index([sku])
  @@index([subcategoryId])
  @@index([availability])
  @@index([isFeatured])
  @@index([isNew])
  @@index([slug])
  @@map("products")
}

// ============================================
// ИЗОБРАЖЕНИЯ ПРОДУКТОВ
// ============================================
model ProductImage {
  id         Int      @id @default(autoincrement())
  productId  Int
  imageUrl   String
  altText    String?
  sortOrder  Int      @default(0)
  isPrimary  Boolean  @default(false)
  createdAt  DateTime @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@map("product_images")
}

// ============================================
// АТРИБУТЫ ПРОДУКТОВ
// ============================================
model ProductAttribute {
  id             Int      @id @default(autoincrement())
  productId      Int
  attributeName  String
  attributeValue String
  createdAt      DateTime @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, attributeName])
  @@index([productId])
  @@map("product_attributes")
}

// ============================================
// АДМИН ПОЛЬЗОВАТЕЛИ
// ============================================
model AdminUser {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  name      String
  role      String   @default("admin")
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("admin_users")
}

// ============================================
// ЛОГИ ИМПОРТА
// ============================================
model ImportLog {
  id           Int      @id @default(autoincrement())
  fileName     String
  status       String
  createdCount Int      @default(0)
  updatedCount Int      @default(0)
  errorCount   Int      @default(0)
  errors       String?
  createdAt    DateTime @default(now())

  @@map("import_logs")
}

// ============================================
// КОНТАКТНАЯ ФОРМА (CRM)
// ============================================
model ContactFormSubmission {
  id        Int      @id @default(autoincrement())
  name      String
  phone     String
  email     String?
  topic     String
  message   String?
  status    String   @default("new")
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([topic])
  @@index([createdAt])
  @@map("contact_form_submissions")
}

// ============================================
// БЛОКИ СТРАНИЦ (Page Builder)
// ============================================
model PageBlock {
  id          Int      @id @default(autoincrement())
  page        String   // "home", "about", "catalog", etc.
  blockType   String   // "hero", "stats", "partners", "factory", "export", "contact_form", "text", "image", "products"
  title       String   // Название блока для админки
  isEnabled   Boolean  @default(true)
  order       Int      @default(0)
  
  // Контент блока (JSON строка зависит от blockType)
  content     String     
  
  // Настройки отображения
  bgColor     String   @default("white") // "white", "gray", "gradient"
  paddingTop  String   @default("lg")    // "sm", "md", "lg", "xl"
  paddingBottom String @default("lg")
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([page, order])
  @@index([page, isEnabled])
  @@map("page_blocks")
}
