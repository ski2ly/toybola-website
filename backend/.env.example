# Database
DATABASE_URL="postgresql://toybola_user:toybola_pass@localhost:5432/toybola_db?schema=public"

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRATION=24h

# Upload
UPLOAD_PATH=./uploads
MAX_FILE_SIZE=10485760

# API
API_PREFIX=/api/v1
PORT=3000
