# Database
DATABASE_URL="postgresql://toybola_user:toybola_pass@localhost:5432/toybola_db?schema=public"

# JWT (REQUIRED - must be set in production)
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRATION=24h

# Admin (for seed script)
ADMIN_PASSWORD=admin123

# CORS
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Upload
UPLOAD_PATH=./uploads
MAX_FILE_SIZE=10485760

# API
API_PREFIX=/api/v1
PORT=3000
